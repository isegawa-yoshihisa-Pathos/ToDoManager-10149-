rules_version = '2';
// Firebase Console または `firebase deploy --only storage` でデプロイしてください。
// チャット添付はクライアントが chat/ 以下へアップロードします。
service firebase.storage {
  match /b/{bucket}/o {
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /chat/{path=**} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.size < 9 * 1024 * 1024;
      allow update, delete: if false;
    }
  }
}
